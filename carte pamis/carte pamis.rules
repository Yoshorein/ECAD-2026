
(rules PCB carte pamis.dsn
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout off)
    (autoroute on)
    (postroute off)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 1)
    (layer_rule F.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.7)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.4)
    )
  )
  (rule
    (width 200.0)
    (clearance 200.0)
    (clearance 100.0 (type smd_to_turn_gap))
    (clearance 50.0 (type smd))
    (clearance 200.0 (type "kicad_default"))
  )
  (padstack "Via[0-1]_600:300_um"
    (shape
      (circle F.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 600.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_600:300_um" "Via[0-1]_600:300_um" default
  )
  (via 
    "Via[0-1]_600:300_um-kicad_default" "Via[0-1]_600:300_um" "kicad_default"
  )
  (via_rule
    default "Via[0-1]_600:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_600:300_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    "Net-(D1-K)" +5V GND TIRETTE +BATT +3V3 "Net-(J6-Pin_3)" "Net-(J6-Pin_1)"
    "Net-(J6-Pin_2)" "Net-(J6-Pin_4)" "DIR G" "STEP G" "Net-(D2-K)" "STEP D" SW "DIR D"
    EN trig "unconnected-(U2-UART-Pad12)" "unconnected-(U2-SPRD-Pad13)" "unconnected-(U2-PDN-Pad11)" "Net-(JP4-B)" "Net-(JP3-B)" "unconnected-(U3-PDN-Pad11)"
    echo "unconnected-(U3-SPRD-Pad13)" "servo 1" "Net-(JP2-B)" "unconnected-(U3-UART-Pad12)" "Net-(JP1-B)" "servo 2" "Net-(D3-A)"
    "Net-(D4-A)" "Net-(D5-A)" "Net-(J4-Pin_1)" "Net-(J7-Pin_1)" "Net-(J3-Pin_1)" "Net-(J7-Pin_3)" "Net-(J7-Pin_2)" "Net-(J7-Pin_4)"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)